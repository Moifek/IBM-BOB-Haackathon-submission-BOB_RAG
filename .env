# BobRAG-MD environment variables
# Copy to .env and fill in your values. Never commit .env.

# ────────────────────────────────────────────────────────
# Google Gemini — primary LLM
# Get key: https://aistudio.google.com/apikey
# ────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ────────────────────────────────────────────────────────
# Langfuse — observability
# Self-hosted via docker-compose; cloud also OK.
# ────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-24933c7d-04c7-47e6-8ccc-e3a4f44f90e8
LANGFUSE_SECRET_KEY=sk-lf-294d917b-9982-4baf-ac52-f7e6abf9a602
LANGFUSE_HOST=http://localhost:3000

# ────────────────────────────────────────────────────────
# Qdrant — vector store (local Docker)
# ────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=bobrag_medical

# ────────────────────────────────────────────────────────
# Pipeline config
# ────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=384
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

LOG_LEVEL=INFO
